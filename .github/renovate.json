{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "baseBranchPatterns": [
    "dev"
  ],
  "labels": [
    "dependencies",
    "renovate"
  ],
  "schedule": [
    "before 9am on monday"
  ],
  "dependencyDashboard": true,
  "rangeStrategy": "bump",
  "vulnerabilityAlerts": {
    "enabled": true
  },
  "pip_requirements": {
    "managerFilePatterns": [
      "/^requirements-dev\\.txt$/",
      "/^virtual-meter/requirements\\.txt$/"
    ]
  }
}
